# =====================================================================
# 環境変数サンプル
# このファイルをコピーして .env.local を作り、実値を入れてください。
#   PowerShell:  Copy-Item .env.example .env.local
# Vite では変数名を必ず VITE_ で始めること（ブラウザに露出する点に留意）。
# .env.local は GitHub に上げない（.gitignore 済み）。本番は Vercel の環境変数に登録。
# =====================================================================

# --- 簡易パスワードゲート（本格認証ではない。本番では変更すること） ---
VITE_ACCESS_PASSWORD=gakushoku2026
VITE_STAFF_PASSWORD=staff2026

# --- 決済モード: mock（デモ） か paypay（サンドボックス/本番） ---
# paypay にすると /api/paypay 経由でリダイレクト決済になる（Vercel 上でのみ動作）。
# ローカルの npm run dev では mock のままにすること。
VITE_PAYMENT_MODE=mock

# --- PayPay（任意 / paypay モード時のみ）---
# ⚠ これらは「秘密情報」。VITE_ を付けない＝ブラウザに露出させない（サーバー関数 /api でのみ使用）。
# PayPay for Developers のダッシュボード（サンドボックス）で取得し、Vercel の環境変数に登録する。
# ローカルで /api を試す場合は `vercel dev` を使う（npm run dev では /api は動かない）。
PAYPAY_API_KEY=
PAYPAY_API_SECRET=
PAYPAY_MERCHANT_ID=

# --- Firebase（任意） ---
# 下の6つを「すべて」設定すると Firestore でのリアルタイム端末間同期が有効になります。
# 1つでも空なら、自動でローカル簡易同期（同一PCの別タブ間）にフォールバックします。
# 値は Firebase コンソール → プロジェクト設定 → マイアプリ（ウェブ）から取得。
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
